# Google resource IDs used when filing receipts
SPREADSHEET_ID=your_google_sheet_id
DRIVE_FOLDER_ID=your_google_drive_folder_id
SHEET_NAME=Sheet1

# Optional: set this to enable auto-extraction of receipt fields via OpenAI
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: override the OpenAI-compatible API base URL to use a local LLM
# e.g. for Ollama: OPENAI_BASE_URL=http://localhost:11434/v1
# e.g. for LM Studio: OPENAI_BASE_URL=http://localhost:1234/v1
OPENAI_BASE_URL=

# Optional: override the model used for receipt field extraction
# Defaults to gpt-4o-mini; set to your local model name when using a local LLM
OPENAI_MODEL=gpt-4o-mini

# Optional: override where runtime files are stored (defaults to the app directory)
# HSA_DATA_DIR=/path/to/writable/dir
